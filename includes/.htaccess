# =============================================
# URS Pharmacy ERP SaaS
# =============================================

Options -Indexes

# حماية ملفات حساسة
<FilesMatch "^\.env|\.error\.log|config\.php\.backup$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Security Headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

RewriteEngine On

# منع الوصول لمجلدات حساسة
RewriteRule ^migrations/ - [F,L]
RewriteRule ^cron/ - [F,L]
RewriteRule ^includes/services/ - [F,L]
RewriteRule ^includes/helpers/ - [F,L]

# Remove .php extension (ALL files including subdirectories)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.+?)/?$ $1.php [QSA,L]

# Redirect .php URLs to clean URLs (GET only — not POST/AJAX)
RewriteCond %{REQUEST_METHOD} GET
RewriteCond %{THE_REQUEST} \s/(.+?)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
