# =============================================
# URS Pharmacy ERP SaaS - Environment Configuration
# =============================================
# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك
# لا ترفع ملف .env إلى Git أبداً

# === Database ===
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_strong_password_here
DB_CHARSET=utf8mb4

# === Application ===
APP_NAME="URS Pharmacy ERP"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.com
APP_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_STRING

# === Session ===
SESSION_LIFETIME=120
SESSION_SECURE=true
SESSION_HTTPONLY=true
SESSION_SAMESITE=Strict

# === Security ===
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
PASSWORD_MIN_LENGTH=8
CSRF_TOKEN_LIFETIME=3600

# === SaaS ===
SAAS_MODE=true
SUPER_ADMIN_EMAIL=admin@yourdomain.com

# === ZATCA ===
ZATCA_ENV=sandbox
ZATCA_API_URL=
ZATCA_API_KEY=
ZATCA_CERTIFICATE=

# === SFDA ===
SFDA_API_URL=
SFDA_API_KEY=

# === Mail ===
MAIL_DRIVER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="URS Pharmacy"

# === Backup ===
BACKUP_PATH=/backups
BACKUP_RETENTION_DAYS=30
